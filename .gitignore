# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/
build/
dist/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Secrets
.env
*.pem

# Project: raw data is gitignored except the manifest and README
/data/raw/*
!/data/raw/manifest.csv
!/data/raw/README.md
# Exception: Phase 1 sandbox cannot reach external hosts, so raw files are
# fetched on an external machine via scripts/fetch_raw.py and committed.
# See docs/deviations.md entry "2026-04-18 — Committing raw files due to
# sandbox egress block". Whitelist each source subdir that fetch_raw.py
# writes to (mirrors the pull_ids/local_paths in scripts/raw_sources.yaml).
!/data/raw/spc/
!/data/raw/spc/**
!/data/raw/datacentermap/
!/data/raw/datacentermap/**
# Per-metro HTML is ~100-200 KB × 490 metros ≈ 50-100 MB committed to the
# repo. Matches the SPC pattern (raw SPC CSVs are also committed) and
# the deviation in docs/deviations.md covering "raw files in git under the
# sandbox-egress-block workaround". Derived JSONL lives under
# data/processed/ and is NOT committed — regenerate with
# `python scripts/scrape_datacentermap.py --build-only`.

# Project: processed data and figures are not committed
/data/processed/*
!/data/processed/.gitkeep
/figures/*
!/figures/.gitkeep
