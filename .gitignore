# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.venv/
venv/
env/
build/
dist/

# OS / editors
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Secrets
.env
*.pem

# Project: raw data is gitignored except the manifest and README
/data/raw/*
!/data/raw/manifest.csv
!/data/raw/README.md
# Exception: Phase 1 sandbox cannot reach external hosts, so raw files are
# hand-uploaded via the GitHub web UI. See docs/deviations.md entry
# "2026-04-18 — Committing raw files due to sandbox egress block".
!/data/raw/spc/
!/data/raw/spc/**

# Project: processed data and figures are not committed
/data/processed/*
!/data/processed/.gitkeep
/figures/*
!/figures/.gitkeep
